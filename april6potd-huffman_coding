import java.util.*;

class Node {
    int data;
    int idx;
    Node left;
    Node right;

    Node(int data, int idx) {
        this.data = data;
        this.idx = idx;
        this.left = null;
        this.right = null;
    }
}

class Solution {

    // Comparator for Min Heap
    static class Compare implements Comparator<Node> {
        public int compare(Node a, Node b) {
            if (a.data == b.data) {
                return a.idx - b.idx; // smaller idx first
            }
            return a.data - b.data; // smaller frequency first
        }
    }

    // DFS to generate codes
    void solve(Node root, String s, ArrayList<String> ans) {
        if (root == null) return;

        // Leaf node
        if (root.left == null && root.right == null) {
            if (s.length() == 0) {
                s = "0";
            }
            ans.add(s);
            return;
        }

        solve(root.left, s + '0', ans);
        solve(root.right, s + '1', ans);
    }

    public ArrayList<String> huffmanCodes(String s, int[] f) {
        PriorityQueue<Node> minHeap = new PriorityQueue<>(new Compare());

        // Insert nodes
        for (int i = 0; i < f.length; i++) {
            minHeap.add(new Node(f[i], i));
        }

        // Build Huffman Tree
        while (minHeap.size() > 1) {
            Node left = minHeap.poll();
            Node right = minHeap.poll();

            Node node = new Node(left.data + right.data, Math.min(left.idx, right.idx));
            node.left = left;
            node.right = right;

            minHeap.add(node);
        }

        Node root = minHeap.peek();

        ArrayList<String> ans = new ArrayList<>();
        solve(root, "", ans);

        return ans;
    }
}
